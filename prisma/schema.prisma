generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  email               String?  @unique
  password_hash       String
  user_type           String   @default("user") // admin, user, vip1, vip2, vip3, vip4
  registration_time   BigInt
  remaining_posts     Int      @default(0)
  user_status         String   @default("active") // active, inactive, suspended, pending_verification
  plan_expires_at     BigInt?
  renewal_notified_at BigInt?
  password_reset_code String?
  verification_code   String?
  code_expires_at     BigInt?
  bound_site_id       Json?    // Array of bound site IDs
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Product {
  id                String   @id @default(uuid())
  name              String   // Mapped from 'Text' in Lark
  description       String   
  short_description String?  
  price             Float    @default(0)
  category          String?
  specifications    String?  // JSON string
  slug              String   @unique
  featured_image    Json?    // Array of image objects or URLs
  is_featured       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model IndustrySite {
  id                   String   @id @default(uuid())
  site_name            String
  site_title           String?  
  industry_name        String?
  sub_domain           String   @unique
  subdomain            String?  // Alias since API uses both
  meta_description     String?  
  logo                 Json?    
  favicon              Json?
  contact_email        String?
  contact_phone        String?
  address              String?  
  social_links         String?  
  
  // Style and config fields from Lark Base
  ssl_status           String?
  header_style_id      String?
  footer_style_id      String?
  banner_style_id      String?
  news_detail_style_id String?
  news_list_style_id   String?
  site_status          String?  @default("active")
  bound_user_id        String?
  ai_news_toggle       Boolean? @default(false)
  about_text           String?  

  is_active        Boolean  @default(true)
  custom_css       String?  

  // === Per-site Cloudflare Credentials ===
  cf_account_id    String?   // Account ID from new subdomain CF account
  cf_api_token     String?   // API Token scoped to this CF account
  cf_zone_id       String?   // Optional zone ID (usually main acct zone is reused)
  cf_email         String?   // CF account email e.g. lasercleaner@c9.pub
  cf_dns_created   Boolean?  @default(false)  // Whether CNAME was created in CF


  // === AI News Automation ===
  ai_news_enabled  Boolean?  @default(false)  // Master AI toggle (replaces ai_news_toggle)
  ai_news_count    Int?      @default(2)       // Articles per day (senior requires 2)
  ai_focus_keyword String?                     // Main keyword for AI generation
  ai_last_run      BigInt?                     // Timestamp of last AI news run

  // === Full SEO Settings (RankMath-style) ===
  seo_title        String?   // Custom <title> tag
  seo_description  String?   // Meta description (150-160 chars recommended)
  seo_keywords     String?   // Comma-separated focus keywords
  og_title         String?   // Open Graph title
  og_description   String?   // Open Graph description
  og_image         String?   // OG image URL
  canonical_url    String?   // Canonical URL
  robots_meta      String?   @default("index,follow")
  schema_type      String?   @default("NewsMediaOrganization")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NewsContent {
  id               String   @id @default(uuid())
  title            String
  content          String   
  industry         String?
  publication_time BigInt?
  summary          String?  
  thumbnail        Json?    // Array of image objects or URLs
  author           String?
  status           String   @default("Draft") // Published, Draft
  source           String?
  is_featured      Boolean  @default(false)
  slug             String   @unique
  original_url     String?  
  related_products Json?    // Array of related product IDs

  // === Per-article SEO (RankMath-style) ===
  seo_title        String?   // Custom SEO title (overrides article title in <title>)
  meta_description String?   // Meta description (150-160 chars recommended)
  focus_keyword    String?   // Primary keyword for SEO score computation
  og_image_url     String?   // OG image URL (overrides thumbnail)
  canonical_url    String?   // Canonical URL for this article
  robots_meta      String?   @default("index,follow")
  seo_score        Int?      // Computed score 0-100

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PlanCoupon {
  id              String   @id @default(uuid())
  type            String   // 'Plan' or 'Coupon'
  name            String
  code            String?  @unique
  price           Float?
  discount_amount Float?
  billing_cycle   String?  // 'monthly', 'yearly', 'one-time'
  duration_days   Int?
  max_uses        Int?
  current_uses    Int      @default(0)
  is_active       Boolean  @default(true)
  valid_until     BigInt?
  features        String?  // JSON string
  limits          String?  // JSON string
  stripe_price_id String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminSetting {
  id          String   @id @default(uuid())
  key         String   @unique // Mapped from 'Key' or 'Setting Name'
  value       String   
  description String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
